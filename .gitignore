# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
env/
.venv/
venv/
ENV/

# Local env/config
.env
.env.*
!.env.example

# Local data generated by the ingestion pipeline
data/serenity.sqlite
data/serenity.sqlite-*
data/raw/*.json
export/

# Browser-copied X curl commands contain cookies/tokens
x_curl/*.curl

# HeroSMS API key (secret) — never commit
.herosms.key
herosms.key

# Logs and OS/editor noise
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
